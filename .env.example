# ─────────────────────────────────────────────────────────────
# Pixel Canvas Live — variables de entorno
# Copia este archivo a .env y ajusta los valores.
# ─────────────────────────────────────────────────────────────

# ── Frontend (Fase 1) ────────────────────────────────────────
# Base de la API. Vacío = usar el backend simulado en memoria (mock).
VITE_API_BASE=""
# "mock" usa datos simulados (Fase 1). "live" consume la API real (Fase 2+).
VITE_DATA_SOURCE="mock"

# ── Servidor (Fase 2+) ───────────────────────────────────────
PORT=3000
NODE_ENV=development
DATABASE_URL="file:./data/canvas.db"
UPLOADS_PATH=./uploads/sounds
SESSION_SECRET="cambia-esto-por-una-cadena-aleatoria-de-32-caracteres-minimo"
FRONTEND_ORIGIN=http://localhost:5173
LOG_FILE_PATH=./logs/server.log
BACKUP_PATH=./backups

# Reconexion con la plataforma de live (Fase 3)
PLATFORM_RECONNECT_INITIAL_DELAY_SECONDS=10
PLATFORM_RECONNECT_MAX_ATTEMPTS=5
PLATFORM_RECONNECT_MULTIPLIER=2

# Bloqueo por intentos fallidos de PIN (Fase 2)
PIN_MAX_ATTEMPTS_PER_GROUP=3
PIN_LOCKOUT_MINUTES=1440
PIN_LOCKOUT_MULTIPLIER=2
PIN_MAX_GROUPS=2
